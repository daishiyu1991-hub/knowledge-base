# DashVector 配置
DASHVECTOR_API_KEY=your_dashvector_api_key
DASHVECTOR_ENDPOINT=your_cluster_endpoint

# DashScope 配置 (Embedding)
DASHSCOPE_API_KEY=your_dashscope_api_key

# Shared API key for Hermes -> memory-service requests
MEMORY_SERVICE_API_KEY=replace_with_a_long_random_secret

# Local dev only — do NOT enable in production (in-memory vector store; search data lost on restart)
# MEMORY_MOCK=1

# 服务配置
PORT=3010
HOST=0.0.0.0

# SQLite 备份
DB_PATH=./data/memories.db
